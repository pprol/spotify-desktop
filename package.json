{
  "name": "electronfy",
  "productName": "Electronfy",
  "version": "1.0.7",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dist": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:appimage": "electron-builder --linux AppImage",
    "dist:deb": "electron-builder --linux deb"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Spotify desktop application for Linux, Windows, and Mac.",
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "app.electronfy",
    "productName": "Electronfy",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "index.js",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        }
      ],
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon2.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "include": "build/installer.nsh"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Graphics",
      "maintainer": "WeWeBunnyX <145664273+WeWeBunnyX@users.noreply.github.com>"
    }
  }
}
